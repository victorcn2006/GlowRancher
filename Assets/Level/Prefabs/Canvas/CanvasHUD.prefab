  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "En el lejano Rancho Slime, Slime Rosa fue una de las primeras slimes en
    aparecer. Su color rosa brillante y su forma adorable la hicieron la favorita
    de todos, \xA1y lo mejor es que siempre estaba saltando por todo el lugar!\n\nUn
    d\xEDa, Slime Rosa descubri\xF3 un campo lleno de frutas frescas y comenz\xF3
    a comerlas. \xA1El sabor fue tan delicioso que hizo que su cuerpo se volviera
    a\xFAn m\xE1s brillante y sus saltos m\xE1s altos! Gracias a su habilidad para
    saltar tan alto, Slime Rosa ayudaba a los nuevos slimes a llegar a los lugares
    m\xE1s altos y recoger frutas para todos.\n\nCon el tiempo, Slime Rosa se convirti\xF3
    en la primera slime del rancho que los cuidadores conoc\xEDan, siempre alegre
    y lista para compartir su energ\xEDa positiva. Su habilidad para hacer que todo
    fuera m\xE1s divertido la convirti\xF3 en la m\xE1s querida de todos."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
